# BrokerFlow AI — Environment Variable Template
#
# Copy this file to ".env" and fill in real values. NEVER commit ".env".
# (.env is already excluded in .gitignore; only this .example file is tracked.)
#
# This is a STATIC site on Vercel. These variables are NOT consumed by the
# front-end at runtime. They document the shared secrets and endpoints used by
# the GPT Actions and downstream automations (n8n / Zapier / Make / CRM), and
# serve as the canonical reference when configuring those connectors.
#
# Core principle: BrokerFlow AI may recommend, draft, prepare, route, and log,
# but never approves, declines, qualifies, guarantees, underwrites, or funds.
# Every funding decision routes to human review.
#
# === 1. Site / Deployment ===
#
# Public canonical URL of the deployed site (used in docs, sitemap, embeds).
SITE_URL="https://brokerflow-ai.vercel.app"
#
# The public GPT access URL surfaced in the UI ("Open the agent" buttons).
GPT_PUBLIC_URL="https://chatgpt.com/g/g-6a214c8c41d48191bebafa39c853412f-loan-broker-automation-architect"
#
# Deployment environment: development | preview | production
APP_ENV="development"
#
# === 2. Webhook Automation Endpoints (No-Auth Tier) ===
#
# Base URL of your automation platform's inbound webhooks (n8n/Zapier/Make).
# Individual paths below are appended to this base.
WEBHOOK_BASE_URL="https://your-automation-host.example.com/webhook"
#
# Shared secret echoed in every webhook envelope ("shared_secret" field) so the
# receiving workflow can verify the call originated from the GPT Actions layer.
# Generate a long random string. Rotate periodically.
WEBHOOK_SHARED_SECRET="replace-with-long-random-string"
#
# Individual no-auth endpoint paths (relative to WEBHOOK_BASE_URL).
WEBHOOK_PATH_HEALTH="/health"
WEBHOOK_PATH_LEAD_INTAKE="/lead-intake"
WEBHOOK_PATH_DOCUMENT_CHECKLIST="/document-checklist"
WEBHOOK_PATH_DEAL_STATUS="/deal-status"
WEBHOOK_PATH_LENDER_MATCH_REVIEW="/lender-match-review"
WEBHOOK_PATH_REFERRAL_PARTNER_EVENT="/referral-partner-event"
WEBHOOK_PATH_PIPELINE_SUMMARY="/pipeline-summary"
#
# === 3. API Key Tier (CRM / Pipeline / Airtable connectors) ===
#
# Used by Actions configured with API Key auth. Choose the scheme your provider
# expects: Basic, Bearer, or a custom header (e.g. X-Api-Key).
API_KEY_AUTH_SCHEME="bearer"             # basic | bearer | custom-header
API_KEY_CUSTOM_HEADER_NAME="X-Api-Key"   # used only when scheme = custom-header
#
# Generic CRM connector
CRM_API_BASE_URL="https://api.your-crm.example.com"
CRM_API_KEY="replace-with-crm-api-key"
#
# Airtable (optional — lightweight pipeline/data store)
AIRTABLE_API_KEY="replace-with-airtable-pat"
AIRTABLE_BASE_ID="appXXXXXXXXXXXXXX"
AIRTABLE_TABLE_NAME="Deals"
#
# === 4. OAuth Tier (Google Drive / Calendar / HubSpot / QuickBooks) ===
#
# Used by Actions configured with OAuth. Token exchange may be default POST or
# Basic-authorization-header depending on the provider.
OAUTH_TOKEN_EXCHANGE_METHOD="default-post"   # default-post | basic-header
#
# HubSpot
HUBSPOT_CLIENT_ID="replace-with-hubspot-client-id"
HUBSPOT_CLIENT_SECRET="replace-with-hubspot-client-secret"
HUBSPOT_REDIRECT_URI="https://brokerflow-ai.vercel.app/oauth/hubspot/callback"
#
# Google (Drive + Calendar)
GOOGLE_CLIENT_ID="replace-with-google-client-id"
GOOGLE_CLIENT_SECRET="replace-with-google-client-secret"
GOOGLE_REDIRECT_URI="https://brokerflow-ai.vercel.app/oauth/google/callback"
#
# QuickBooks (optional)
QUICKBOOKS_CLIENT_ID="replace-with-quickbooks-client-id"
QUICKBOOKS_CLIENT_SECRET="replace-with-quickbooks-client-secret"
QUICKBOOKS_REDIRECT_URI="https://brokerflow-ai.vercel.app/oauth/quickbooks/callback"
#
# === 5. Internal Alerts / Notifications ===
#
# Where "Send Internal Broker Alert" actions route (Slack/email relay webhook).
INTERNAL_ALERT_WEBHOOK_URL="https://hooks.slack.com/services/XXXX/XXXX/XXXX"
#
# Default human-review queue owner (email) for routed decisions.
HUMAN_REVIEW_CONTACT_EMAIL="broker@moonshinecapital.example.com"
#
# === 6. Feature Flags (optional) ===
#
# Toggle non-production behaviors. Keep human_review_required ON everywhere.
FEATURE_HUMAN_REVIEW_REQUIRED="true"
FEATURE_VERBOSE_LOGGING="false"