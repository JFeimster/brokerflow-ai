{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "outputDirectory": ".",
  "git": { "deploymentEnabled": true },
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/api/no-auth/qualify-funding-lead", "destination": "/api/no-auth/lead-intake-actions" },
    { "source": "/api/no-auth/score-borrower-readiness", "destination": "/api/no-auth/lead-intake-actions" },
    { "source": "/api/no-auth/detect-missing-funding-info", "destination": "/api/no-auth/lead-intake-actions" },
    { "source": "/api/no-auth/classify-funding-scenario", "destination": "/api/no-auth/lead-intake-actions" },
    { "source": "/api/no-auth/normalize-broker-lead", "destination": "/api/no-auth/lead-intake-actions" },
    { "source": "/api/no-auth/rank-lender-options", "destination": "/api/no-auth/lender-routing-actions" },
    { "source": "/api/no-auth/generate-lender-shortlist", "destination": "/api/no-auth/lender-routing-actions" },
    { "source": "/api/no-auth/flag-manual-review-required", "destination": "/api/no-auth/lender-routing-actions" },
    { "source": "/api/no-auth/generate-document-checklist", "destination": "/api/no-auth/document-checklist-actions" },
    { "source": "/api/no-auth/audit-submitted-documents", "destination": "/api/no-auth/document-checklist-actions" },
    { "source": "/api/no-auth/detect-missing-documents", "destination": "/api/no-auth/document-checklist-actions" },
    { "source": "/api/no-auth/create-borrower-submission-packet", "destination": "/api/no-auth/document-checklist-actions" },
    { "source": "/api/no-auth/summarize-funding-file", "destination": "/api/no-auth/document-checklist-actions" }
  ],
  "redirects": [
    { "source": "/home", "destination": "/", "permanent": true },
    { "source": "/agent", "destination": "/agents", "permanent": true },
    { "source": "/widget", "destination": "/embed", "permanent": true }
  ]
}
